{
  "name": "aidog",
  "version": "0.1.1",
  "description": "OpenClaw agent optimization toolkit for reducing AI coding cost, improving performance, and scanning security risks",
  "type": "module",
  "bin": {
    "aidog": "bin/aidog.js"
  },
  "scripts": {
    "dev": "node bin/aidog.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:web": "cd src/web && npx vite build",
    "docs:screenshots": "node scripts/generate-readme-screenshots.mjs",
    "lint": "eslint src/ tests/",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "codex",
    "gemini",
    "openclaw",
    "token",
    "cost",
    "cost-optimization",
    "security",
    "security-scan",
    "performance",
    "performance-optimization",
    "dashboard",
    "cli"
  ],
  "author": "aiaido",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIAIDO/aidog.git"
  },
  "homepage": "https://github.com/AIAIDO/aidog",
  "bugs": {
    "url": "https://github.com/AIAIDO/aidog/issues"
  },
  "files": [
    "bin/",
    "src/",
    "!src/web/node_modules/",
    "!src/web/src/",
    "!src/web/index.html",
    "!src/web/package.json",
    "!src/web/package-lock.json",
    "!src/web/postcss.config.js",
    "!src/web/tailwind.config.js",
    "!src/web/vite.config.js",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-yaml": "^4.1.0",
    "openai": "^4.80.0",
    "ora": "^8.1.1",
    "react-i18next": "^16.5.6",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
